@inject NavigationManager NavigationManager
@using Radzen.Blazor
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="@NavigationManager.BaseUri" />

    <ResourcePreloader />
    <RadzenTheme Theme="material" @rendermode="InteractiveServer" />

    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["AndreGoepel.AppFoundation.styles.css"]" />
    <link rel="icon" type="image/png" href="favicon.png" />
    <style>.reveal{opacity:0}.hero{min-height:100vh}</style>

    <HeadOutlet @rendermode="@InteractiveServer" />
</head>

<body>
    <Routes @rendermode="InteractiveServer" />
    <script src="_content/AndreGoepel.Website/js/site.js"></script>
    <script src="@Assets["_framework/blazor.web.js"]"></script>
    <script src="_content/Radzen.Blazor/Radzen.Blazor.js"></script>
</body>

</html>
