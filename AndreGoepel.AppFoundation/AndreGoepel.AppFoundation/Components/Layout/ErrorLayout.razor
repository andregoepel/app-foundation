@inherits LayoutComponentBase
@inject IJSRuntime JS

<HeadContent>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,400;0,500;0,600;1,400&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="_content/AndreGoepel.Website/css/app.css" />
</HeadContent>

@Body

@code {
    private bool _isInteractive;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        _isInteractive = true;
        var state = await JS.InvokeAsync<InitialState>("site.getInitialState");
        await JS.InvokeVoidAsync("site.applyAttrs", state.ResolvedTheme, state.Lang);
    }

    private record InitialState(string Lang, string Theme, string ResolvedTheme);
}
