<Router AppAssembly="@typeof(Program).Assembly"
        AdditionalAssemblies="new[] { typeof(AndreGoepel.Marten.Identity.Blazor.Initialization).Assembly, typeof(AndreGoepel.Website.Initialization).Assembly }">
    <Found Context="routeData">
        <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)">
            <NotAuthorized Context="_">
                <AuthorizeView>
                    <Authorized Context="__">
                        <ErrorPage Code="403" />
                    </Authorized>
                    <NotAuthorized Context="___">
                        <RedirectToLogin />
                    </NotAuthorized>
                </AuthorizeView>
            </NotAuthorized>
            <Authorizing />
        </AuthorizeRouteView>
        <FocusOnNavigate RouteData="@routeData" Selector="h1" />
    </Found>
    <NotFound>
        <AndreGoepel.AppFoundation.Components.Pages.NotFound />
    </NotFound>
</Router>
