<section id="about" class="sec sec-about">
    <div class="sec-inner about-grid">
        <div class="about-col-l">
            <div class="reveal kicker">@About.Kicker</div>
            <h2 class="reveal sec-title" style="transition-delay: 60ms">@About.Title</h2>
            <div class="about-portrait" aria-hidden="true">
                <div class="about-portrait-inner">
                    <div class="about-portrait-mono">AG</div>
                    <div class="about-portrait-ring"></div>
                    <div class="about-portrait-ring r2"></div>
                </div>
                <div class="about-portrait-meta">
                    <span class="about-status">
                        <span></span> available · Q3 2026
                    </span>
                </div>
            </div>
        </div>
        <div class="about-col-r">
            @for (int i = 0; i < About.Body.Count; i++)
            {
                var text = About.Body[i];
                var delay = 80 + i * 100;
                <p class="reveal about-p" style="transition-delay: @(delay)ms">@text</p>
            }
            <div class="about-facts">
                @for (int i = 0; i < About.Facts.Count; i++)
                {
                    var fact = About.Facts[i];
                    var delay = 400 + i * 60;
                    <div class="reveal about-fact" style="transition-delay: @(delay)ms">
                        <div class="about-fact-k">@fact.Key</div>
                        <div class="about-fact-v">@fact.Value</div>
                    </div>
                }
            </div>
        </div>
    </div>
</section>

@code {
    [Parameter]
    [EditorRequired]
    public required About About { get; set; }
}
