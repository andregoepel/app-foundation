<section id="contact" class="sec sec-contact">
    <div class="sec-inner contact-inner">
        <div class="reveal kicker">@Contact.Kicker</div>
        <h2 class="reveal sec-title contact-title" style="transition-delay: 60ms">@Contact.Title</h2>
        <p class="reveal contact-body" style="transition-delay: 140ms">@Contact.Body</p>
        <div class="reveal contact-actions" style="transition-delay: 220ms">
            <a href="mailto:andre@andregoepel.dev" class="btn btn-primary btn-lg">
                <span>@Contact.Cta</span>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7" /></svg>
            </a>
        </div>
        <div class="reveal contact-alt" style="transition-delay: 300ms">
            <div>
                <span class="contact-alt-lbl">@Contact.Or</span>
                <a class="contact-mail" href="mailto:andre@andregoepel.dev">andre@andregoepel.dev</a>
            </div>
            <div>
                <span class="contact-alt-lbl">@Contact.LinkedIn</span>
                <a class="contact-mail" href="@Contact.LinkedInUrl" target="_blank" rel="noreferrer">/in/andre-goepel</a>
            </div>
            <div>
                <span class="contact-alt-lbl">@Contact.GitHub</span>
                <a class="contact-mail" href="@Contact.GitHubUrl" target="_blank" rel="noreferrer">/andregoepel</a>
            </div>
        </div>
    </div>
</section>

@code {
    [Parameter]
    [EditorRequired]
    public required Contact Contact { get; set; }
}
