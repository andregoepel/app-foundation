<section id="problem" class="sec sec-problem">
    <div class="sec-inner">
        <div class="reveal kicker">@Problems.Kicker</div>
        <h2 class="reveal sec-title" style="transition-delay: 60ms">@Problems.Title</h2>
        <ul class="problem-list">
            @for (int i = 0; i < Problems.Items.Count; i++)
            {
                var item = Problems.Items[i];
                var delay = 120 + i * 80;
                <li class="reveal problem-item" style="transition-delay: @(delay)ms">
                    <span class="problem-dash" aria-hidden="true">—</span>
                    <span>@item</span>
                </li>
            }
        </ul>
        <p class="reveal problem-footer" style="transition-delay: 500ms">@Problems.Footer</p>
    </div>
</section>

@code {
    [Parameter]
    [EditorRequired]
    public required Problems Problems { get; set; }
}
