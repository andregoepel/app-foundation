@inject SiteStateService State
@inject IJSRuntime JS

<header class="hdr">
    <a href="#top" class="hdr-brand" aria-label="andregoepel.dev">
        <span class="hdr-mark">
            <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
                <circle cx="11" cy="11" r="10" stroke="currentColor" stroke-width="1.4" />
                <path d="M5 14 L11 5 L17 14" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
                <circle cx="11" cy="11" r="2.2" fill="var(--accent)" />
            </svg>
        </span>
        <span class="hdr-wordmark">
            <span>andregoepel</span><span class="hdr-tld">.dev</span>
        </span>
    </a>

    <nav class="hdr-nav" aria-label="Sections">
        @foreach (var (key, label) in Navigation.Links)
        {
            <a href="@($"#{key}")" class="hdr-link" data-nav-section="@key">
                <span class="hdr-link-num">0@(NavKeys.IndexOf(key) + 1)</span>
                <span>@label</span>
            </a>
        }
    </nav>

    <div class="hdr-tools">
        <div class="hdr-seg" role="group" aria-label="@Navigation.LangLabel">
            <button class="@(State.Lang == "en" ? "is-on" : "")" @onclick='() => SetLang("en")' aria-pressed="@(State.Lang == "en")">EN</button>
            <button class="@(State.Lang == "de" ? "is-on" : "")" @onclick='() => SetLang("de")' aria-pressed="@(State.Lang == "de")">DE</button>
        </div>

        <div class="hdr-seg hdr-theme" role="group" aria-label="@Navigation.ThemeLabel">
            <button class="@(State.Theme == "light" ? "is-on" : "")" @onclick='() => SetTheme("light")' title="@Navigation.ThemeOptions["light"]" aria-label="@Navigation.ThemeOptions["light"]">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="4" /><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
                </svg>
            </button>
            <button class="@(State.Theme == "system" ? "is-on" : "")" @onclick='() => SetTheme("system")' title="@Navigation.ThemeOptions["system"]" aria-label="@Navigation.ThemeOptions["system"]">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="2" y="4" width="20" height="14" rx="2" /><path d="M8 22h8M12 18v4" />
                </svg>
            </button>
            <button class="@(State.Theme == "dark" ? "is-on" : "")" @onclick='() => SetTheme("dark")' title="@Navigation.ThemeOptions["dark"]" aria-label="@Navigation.ThemeOptions["dark"]">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
                </svg>
            </button>
        </div>

        <a href="#contact" class="hdr-cta">
            <span>@Navigation.Cta</span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14M13 5l7 7-7 7" />
            </svg>
        </a>
    </div>
</header>

@code {
    [Parameter]
    [EditorRequired]
    public required Navigation Navigation { get; set; }

    private static readonly List<string> NavKeys = ["problem", "services", "about", "cases", "contact"];

    private async Task SetLang(string lang)
    {
        State.SetLang(lang);
        await JS.InvokeVoidAsync("site.savePrefs", lang, State.Theme);
    }

    private async Task SetTheme(string theme)
    {
        var resolvedTheme = theme == "system"
            ? await JS.InvokeAsync<bool>("eval", "window.matchMedia('(prefers-color-scheme: dark)').matches") ? "dark" : "light"
            : theme;
        State.SetTheme(theme, resolvedTheme);
        await JS.InvokeVoidAsync("site.savePrefs", State.Lang, theme);
    }
}
