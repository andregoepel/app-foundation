@inherits LayoutComponentBase

@inject ContentService ContentService
@inject IHttpContextAccessor HttpContextAccessor

<SiteHeader Navigation="@_content.Navigation" Lang="@_lang" />

<main>
    <HeroSection Hero="@_content.Hero" />
    <ProblemsSection Problems="@_content.Problem" />
    <ServicesSection Services="@_content.Services" />
    <AboutSection About="@_content.About" />
    <CasesSection Cases="@_content.Cases" />
    <ContactSection Contact="@_content.Contact" />
    @Body
</main>

<FooterSection Footer="@_content.Footer" />

@code {
    private string _lang = "en";
    private HomeContent _content = HomeContent.Create();

    protected override async Task OnInitializedAsync()
    {
        _lang = SiteLanguage.Resolve(HttpContextAccessor.HttpContext);
        _content = await ContentService.GetAsync(_lang);
    }
}
