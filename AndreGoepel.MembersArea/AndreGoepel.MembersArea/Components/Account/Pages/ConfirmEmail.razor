@page "/Account/ConfirmEmail"

@using System.Text
@using AndreGoepel.Marten.Identity.Users
@using AndreGoepel.MembersArea
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.WebUtilities
@using Radzen

@inject UserManager<User> UserManager
@inject NotificationService NotificationService
@inject IdentityRedirectManager RedirectManager

<PageTitle>Confirm email</PageTitle>

<h1>Confirm email</h1>

@code {
    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    [SupplyParameterFromQuery]
    private string? UserId { get; set; }

    [SupplyParameterFromQuery]
    private string? Code { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (UserId is null || Code is null)
        {
            RedirectManager.RedirectTo("");
            return;
        }

        var user = await UserManager.FindByIdAsync(UserId);
        if (user is null)
        {
            HttpContext.Response.StatusCode = StatusCodes.Status404NotFound;
            NotificationService.Notify(NotificationSeverity.Error, "Error", $"Error loading user with ID {UserId}");
        }
        else
        {
            var code = Encoding.UTF8.GetString(WebEncoders.Base64UrlDecode(Code));
            var result = await UserManager.ConfirmEmailAsync(user, code);
            if (result.Succeeded) 
                NotificationService.Notify(NotificationSeverity.Success, "Thank you for confirming your email."); 
            else 
                NotificationService.Notify(NotificationSeverity.Error, "Error confirming your email.");
        }
    }
}
