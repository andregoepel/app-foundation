@rendermode InteractiveServer

@using AndreGoepel.Marten.Identity.Users
@using Microsoft.AspNetCore.Identity
@using Radzen
@using Radzen.Blazor

@inject UserManager<User> UserManager
@inject SignInManager<User> SignInManager
@inject ILogger<Login> Logger
@inject NavigationManager NavigationManager
@inject IdentityRedirectManager RedirectManager
@inject NotificationService NotificationService

<RadzenTemplateForm TItem="InputModel" Data=@Input Submit=@LoginUser>
    <RadzenStack Gap="1.5rem">

        <div>
            <RadzenLabel Text="Email" Component="Email" />
            <RadzenTextBox @bind-Value=@Input.Email
                           Name="Email"
                           AutoCompleteType="AutoCompleteType.Username"
                           Placeholder="name@example.com"
                           Style="width:100%" />
            <RadzenRequiredValidator Component="Email" Text="Email is required" />
        </div>

        <div>
            <RadzenLabel Text="Password" Component="Password" />
            <RadzenPassword @bind-Value="Input.Password" Name="Password" Style="width:100%" />
            <RadzenRequiredValidator Component="Password" Text="Password is required" />
        </div>

        <RadzenRow AlignItems="AlignItems.Center" RowGap="0.25rem">
            <RadzenColumn Size="1">
                <RadzenCheckBox @bind-Value=@Input.RememberMe Name="RememberMe" />
            </RadzenColumn>
            <RadzenColumn Size="11">
                <RadzenLabel Text="Remember me" Component="RememberMe" />
            </RadzenColumn>
        </RadzenRow>

        <RadzenStack Orientation="Orientation.Horizontal"
                     Gap="1rem"
                     JustifyContent="JustifyContent.Center"
                     Wrap="FlexWrap.Wrap">
            <RadzenButton ButtonType="ButtonType.Submit"
                          Text="Log in"
                          ButtonStyle="ButtonStyle.Primary"
                          Size="ButtonSize.Large"
                          Style="width: 100%; max-width: 360px;" />
        </RadzenStack>

        <RadzenStack Orientation="Orientation.Horizontal" Gap="1.5rem" JustifyContent="JustifyContent.Center" Wrap="FlexWrap.Wrap">
            <RadzenLink Path="Account/ForgotPassword" Text="Forgot your password?" />
            <RadzenLink Path="@(NavigationManager.GetUriWithQueryParameters("Account/Register", new Dictionary<string, object?> { ["ReturnUrl"] = ReturnUrl }))" Text="Register as a new user" />
            <RadzenLink Path="Account/ResendEmailConfirmation" Text="Resend email confirmation" />
        </RadzenStack>

    </RadzenStack>
</RadzenTemplateForm>

@code {
    [SupplyParameterFromForm]
    private InputModel Input { get; set; } = default!;

    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    protected override async Task OnInitializedAsync()
    {
        Input ??= new();
    }

    private async Task LoginUser(InputModel model)
    {
        if (!string.IsNullOrEmpty(model.Passkey?.Error))
        {
            NotificationService.Notify(NotificationSeverity.Error, "LoginError", model.Passkey.Error);
            return;
        }

        SignInResult result;
        if (!string.IsNullOrEmpty(model.Passkey?.CredentialJson))
        {
            result = await SignInManager.PasskeySignInAsync(model.Passkey.CredentialJson);
        }
        else
        {
            var user = await UserManager.FindByEmailAsync(model.Email);
            if (user == null || !(await SignInManager.CanSignInAsync(user)))
            {
                NotificationService.Notify(NotificationSeverity.Error, "LoginError", "Invalid login attempt.");
                return;
            }

            if (await UserManager.IsLockedOutAsync(user))
            {
                Logger.LogWarning("User account locked out.");
                RedirectManager.RedirectTo("Account/Lockout");
                return;
            }

            if (!await UserManager.CheckPasswordAsync(user, model.Password))
            {
                await UserManager.AccessFailedAsync(user);
                NotificationService.Notify(NotificationSeverity.Error, "LoginError", "Invalid login attempt.");
                return;
            }

            // Password valid — hand off to middleware for cookie sign-in (handles 2FA, remember-me, etc.)
            Guid key = Guid.NewGuid();
            CookieLoginMiddleware.Logins[key] = new LoginInfo { Email = model.Email, Password = model.Password, RememberMe = model.RememberMe };
            NavigationManager.NavigateTo($"/login?key={key}", true);
            return;
        }

        // Passkey path: PasskeySignInAsync handles the full sign-in
        if (result.Succeeded)
        {
            Logger.LogInformation("User logged in.");
            RedirectManager.RedirectTo(ReturnUrl);
        }
        else if (result.RequiresTwoFactor)
        {
            RedirectManager.RedirectTo(
                "Account/LoginWith2fa",
                new() { ["returnUrl"] = ReturnUrl, ["rememberMe"] = model.RememberMe });
        }
        else if (result.IsLockedOut)
        {
            Logger.LogWarning("User account locked out.");
            RedirectManager.RedirectTo("Account/Lockout");
        }
        else
        {
            NotificationService.Notify(NotificationSeverity.Error, "LoginError", "Invalid login attempt.");
        }
    }

    private sealed class InputModel
    {
        public string Email { get; set; } = "";
        public string Password { get; set; } = "";
        public bool RememberMe { get; set; }
        public PasskeyInputModel? Passkey { get; set; }
    }
}
