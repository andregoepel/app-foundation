@page "/Account/LoginWith2fa"
@layout LoginLayout
@rendermode InteractiveServer

@using System.ComponentModel.DataAnnotations
@using AndreGoepel.MembersArea.Components.Layout
@using Radzen
@using Radzen.Blazor

@inject NavigationManager NavigationManager
@inject NotificationService NotificationService

<PageTitle>Two-factor authentication – nerdventures.blog</PageTitle>

<RadzenCard class="login-card">
    <div class="login-brand-panel">
        <div class="login-logo-circle">
            <img src="favicon.png" alt="nerdventures.blog" style="width: 40px; height: 40px; object-fit: contain;" />
        </div>
        <RadzenText TagName="TagName.Span" TextStyle="TextStyle.H6" Style="color: white; font-weight: 700; letter-spacing: 0.02em;">nerdventures.blog</RadzenText>
        <RadzenText TagName="TagName.H2" TextStyle="TextStyle.H2" Style="color: white; font-weight: 700; margin-top: 3rem; margin-bottom: 0.75rem;">Welcome!</RadzenText>
        <RadzenText TextStyle="TextStyle.Body1" Style="color: rgba(255,255,255,0.8);">Enter the code from your authenticator app.</RadzenText>
    </div>

    <div class="login-form-panel">
        <RadzenStack Orientation="Orientation.Vertical" Gap="1.5rem" AlignItems="AlignItems.Stretch">

            <RadzenText TagName="TagName.H1" TextStyle="TextStyle.H4">Two-factor authentication</RadzenText>

            <RadzenTemplateForm TItem="InputModel" Data=@Input Submit=@OnSubmitAsync>
                <RadzenStack Gap="1.25rem">

                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="1rem">
                        <RadzenLabel Text="Authenticator code" Component="TwoFactorCode" Style="width: 10rem; flex-shrink: 0;" />
                        <RadzenStack Gap="0.25rem" Style="flex: 1;">
                            <RadzenTextBox @bind-Value=@Input.TwoFactorCode
                                           Name="TwoFactorCode"
                                           Placeholder="6-digit code"
                                           AutoCompleteType="AutoCompleteType.Off"
                                           Style="width:100%" />
                            <RadzenRequiredValidator Component="TwoFactorCode" Text="Authenticator code is required" />
                            <RadzenLengthValidator Component="TwoFactorCode" Min="6" Max="7"
                                                   Text="Code must be 6 or 7 characters" />
                        </RadzenStack>
                    </RadzenStack>

                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                        <RadzenCheckBox @bind-Value=@Input.RememberMachine Name="RememberMachine" />
                        <RadzenLabel Text="Remember this machine" Component="RememberMachine" />
                    </RadzenStack>

                    <div class="login-action-row">
                        <RadzenButton ButtonType="ButtonType.Submit"
                                      Text="Log in"
                                      ButtonStyle="ButtonStyle.Primary"
                                      IsBusy=@isProcessing
                                      BusyText="Verifying..." />

                        <RadzenLink Path="@($"/Account/LoginWithRecoveryCode?returnUrl={ReturnUrl}")"
                                    Text="Use a recovery code instead" />
                    </div>

                </RadzenStack>
            </RadzenTemplateForm>

        </RadzenStack>
    </div>
</RadzenCard>

@code {
    private InputModel Input { get; set; } = new();
    private bool isProcessing;

    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    [SupplyParameterFromQuery]
    private bool RememberMe { get; set; }

    [SupplyParameterFromQuery]
    private string? Error { get; set; }

    protected override void OnInitialized()
    {
        if (Error == "invalid")
        {
            NotificationService.Notify(NotificationSeverity.Error, "2FA Error", "Invalid authenticator code.");
        }
    }

    private async Task OnSubmitAsync(InputModel model)
    {
        isProcessing = true;

        try
        {
            var key = Guid.NewGuid();
            CookieLoginMiddleware.TwoFactorLogins[key] = new TwoFactorLoginInfo
            {
                Code = model.TwoFactorCode!,
                RememberMe = RememberMe,
                RememberMachine = model.RememberMachine,
                ReturnUrl = ReturnUrl,
            };
            NavigationManager.NavigateTo($"/login2fa?key={key}", forceLoad: true);
        }
        finally
        {
            isProcessing = false;
        }
    }

    private sealed class InputModel
    {
        [Required]
        [StringLength(7, MinimumLength = 6)]
        public string? TwoFactorCode { get; set; }

        public bool RememberMachine { get; set; }
    }
}
