@page "/Account/LoginWith2fa"
@rendermode InteractiveServer

@using System.ComponentModel.DataAnnotations
@using Radzen
@using Radzen.Blazor

@inject NavigationManager NavigationManager
@inject NotificationService NotificationService

<PageTitle>Two-factor authentication – nerdventures.blog</PageTitle>

<div class="rz-p-4 rz-p-md-8">
    <RadzenCard>
        <RadzenStack Orientation="Orientation.Vertical" Gap="2rem" AlignItems="AlignItems.Stretch">

            <div class="text-center">
                <RadzenText TextStyle="TextStyle.H3" TagName="TagName.H1">Two-factor authentication</RadzenText>
                <RadzenText TextStyle="TextStyle.Body1" class="rz-color-muted mt-2">
                    Enter the code from your authenticator app.
                </RadzenText>
            </div>

            <RadzenTemplateForm TItem="InputModel" Data=@Input Submit=@OnSubmitAsync>
                <RadzenStack Gap="1.5rem">

                    <div>
                        <RadzenLabel Text="Authenticator code *" Component="TwoFactorCode" />
                        <RadzenTextBox @bind-Value=@Input.TwoFactorCode
                                       Name="TwoFactorCode"
                                       Placeholder="6-digit code"
                                       AutoCompleteType="AutoCompleteType.Off"
                                       Style="width:100%" />
                        <RadzenRequiredValidator Component="TwoFactorCode" Text="Authenticator code is required" />
                        <RadzenLengthValidator Component="TwoFactorCode" Min="6" Max="7"
                                               Text="Code must be 6 or 7 characters" />
                    </div>

                    <RadzenRow AlignItems="AlignItems.Center" RowGap="0.25rem">
                        <RadzenColumn Size="1">
                            <RadzenCheckBox @bind-Value=@Input.RememberMachine Name="RememberMachine" />
                        </RadzenColumn>
                        <RadzenColumn Size="11">
                            <RadzenLabel Text="Remember this machine" Component="RememberMachine" />
                        </RadzenColumn>
                    </RadzenRow>

                    <RadzenStack Orientation="Orientation.Horizontal"
                                 Gap="1rem"
                                 JustifyContent="JustifyContent.Center"
                                 Wrap="FlexWrap.Wrap">
                        <RadzenButton ButtonType="ButtonType.Submit"
                                      Text="Log in"
                                      ButtonStyle="ButtonStyle.Primary"
                                      Size="ButtonSize.Large"
                                      IsBusy=@isProcessing
                                      BusyText="Verifying..."
                                      Style="width: 100%; max-width: 360px;" />
                    </RadzenStack>

                    <RadzenText TextStyle="TextStyle.Body2" class="text-center">
                        Don't have access to your authenticator device?
                        <RadzenLink Path="@($"/Account/LoginWithRecoveryCode?returnUrl={ReturnUrl}")"
                                    Text="Log in with a recovery code" />
                    </RadzenText>

                </RadzenStack>
            </RadzenTemplateForm>

        </RadzenStack>
    </RadzenCard>
</div>

@code {
    private InputModel Input { get; set; } = new();
    private bool isProcessing;

    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    [SupplyParameterFromQuery]
    private bool RememberMe { get; set; }

    [SupplyParameterFromQuery]
    private string? Error { get; set; }

    protected override void OnInitialized()
    {
        if (Error == "invalid")
        {
            NotificationService.Notify(NotificationSeverity.Error, "2FA Error", "Invalid authenticator code.");
        }
    }

    private async Task OnSubmitAsync(InputModel model)
    {
        isProcessing = true;

        try
        {
            var key = Guid.NewGuid();
            CookieLoginMiddleware.TwoFactorLogins[key] = new TwoFactorLoginInfo
            {
                Code = model.TwoFactorCode!,
                RememberMe = RememberMe,
                RememberMachine = model.RememberMachine,
                ReturnUrl = ReturnUrl
            };
            NavigationManager.NavigateTo($"/login2fa?key={key}", forceLoad: true);
        }
        finally
        {
            isProcessing = false;
        }
    }

    private sealed class InputModel
    {
        [Required]
        [StringLength(7, MinimumLength = 6)]
        public string? TwoFactorCode { get; set; }

        public bool RememberMachine { get; set; }
    }
}
