@page "/Account/LoginWithRecoveryCode"
@rendermode InteractiveServer

@using System.ComponentModel.DataAnnotations
@using Radzen
@using Radzen.Blazor

@inject NavigationManager NavigationManager
@inject NotificationService NotificationService

<PageTitle>Recovery code verification – nerdventures.blog</PageTitle>

<div class="rz-p-4 rz-p-md-8">
    <RadzenCard>
        <RadzenStack Orientation="Orientation.Vertical" Gap="2rem" AlignItems="AlignItems.Stretch">

            <div class="text-center">
                <RadzenText TextStyle="TextStyle.H3" TagName="TagName.H1">Recovery code verification</RadzenText>
                <RadzenText TextStyle="TextStyle.Body1" class="rz-color-muted mt-2">
                    This login will not be remembered until you provide an authenticator app code or disable 2FA.
                </RadzenText>
            </div>

            <RadzenTemplateForm TItem="InputModel" Data=@Input Submit=@OnSubmitAsync>
                <RadzenStack Gap="1.5rem">

                    <div>
                        <RadzenLabel Text="Recovery code *" Component="RecoveryCode" />
                        <RadzenTextBox @bind-Value=@Input.RecoveryCode
                                       Name="RecoveryCode"
                                       Placeholder="Enter recovery code"
                                       AutoCompleteType="AutoCompleteType.Off"
                                       Style="width:100%" />
                        <RadzenRequiredValidator Component="RecoveryCode" Text="Recovery code is required" />
                    </div>

                    <RadzenStack Orientation="Orientation.Horizontal"
                                 Gap="1rem"
                                 JustifyContent="JustifyContent.Center"
                                 Wrap="FlexWrap.Wrap">
                        <RadzenButton ButtonType="ButtonType.Submit"
                                      Text="Log in"
                                      ButtonStyle="ButtonStyle.Primary"
                                      Size="ButtonSize.Large"
                                      IsBusy=@isProcessing
                                      BusyText="Verifying..."
                                      Style="width: 100%; max-width: 360px;" />
                    </RadzenStack>

                    <RadzenText TextStyle="TextStyle.Body2" class="text-center">
                        Have your authenticator app? <RadzenLink Path="/Account/LoginWith2fa" Text="Use an authenticator code instead" />
                    </RadzenText>

                </RadzenStack>
            </RadzenTemplateForm>

        </RadzenStack>
    </RadzenCard>
</div>

@code {
    private InputModel Input { get; set; } = new();
    private bool isProcessing;

    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    [SupplyParameterFromQuery]
    private string? Error { get; set; }

    protected override void OnInitialized()
    {
        if (Error == "invalid")
        {
            NotificationService.Notify(NotificationSeverity.Error, "Recovery Code Error", "Invalid recovery code entered.");
        }
    }

    private async Task OnSubmitAsync(InputModel model)
    {
        isProcessing = true;

        try
        {
            var key = Guid.NewGuid();
            CookieLoginMiddleware.RecoveryCodeLogins[key] = new RecoveryCodeLoginInfo
            {
                Code = model.RecoveryCode,
                ReturnUrl = ReturnUrl
            };
            NavigationManager.NavigateTo($"/loginrecovery?key={key}", forceLoad: true);
        }
        finally
        {
            isProcessing = false;
        }
    }

    private sealed class InputModel
    {
        [Required]
        public string RecoveryCode { get; set; } = "";
    }
}
