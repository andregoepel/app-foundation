@page "/Account/LoginWithRecoveryCode"
@layout LoginLayout
@rendermode InteractiveServer

@using System.ComponentModel.DataAnnotations
@using AndreGoepel.MembersArea.Components.Layout
@using Radzen
@using Radzen.Blazor

@inject NavigationManager NavigationManager
@inject NotificationService NotificationService

<PageTitle>Recovery code verification – nerdventures.blog</PageTitle>

<RadzenCard class="login-card">
    <div class="login-brand-panel">
        <div class="login-logo-circle">
            <img src="favicon.png" alt="nerdventures.blog" style="width: 40px; height: 40px; object-fit: contain;" />
        </div>
        <RadzenText TagName="TagName.Span" TextStyle="TextStyle.H6" Style="color: white; font-weight: 700; letter-spacing: 0.02em;">nerdventures.blog</RadzenText>
        <RadzenText TagName="TagName.H2" TextStyle="TextStyle.H2" Style="color: white; font-weight: 700; margin-top: 3rem; margin-bottom: 0.75rem;">Welcome!</RadzenText>
        <RadzenText TextStyle="TextStyle.Body1" Style="color: rgba(255,255,255,0.8);">Use a recovery code to regain access.</RadzenText>
    </div>

    <div class="login-form-panel">
        <RadzenStack Orientation="Orientation.Vertical" Gap="1.5rem" AlignItems="AlignItems.Stretch">

            <RadzenText TagName="TagName.H1" TextStyle="TextStyle.H4">Recovery code verification</RadzenText>

            <RadzenTemplateForm TItem="InputModel" Data=@Input Submit=@OnSubmitAsync>
                <RadzenStack Gap="1.25rem">

                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="1rem">
                        <RadzenLabel Text="Recovery code" Component="RecoveryCode" Style="width: 10rem; flex-shrink: 0;" />
                        <RadzenStack Gap="0.25rem" Style="flex: 1;">
                            <RadzenTextBox @bind-Value=@Input.RecoveryCode
                                           Name="RecoveryCode"
                                           Placeholder="Enter recovery code"
                                           AutoCompleteType="AutoCompleteType.Off"
                                           Style="width:100%" />
                            <RadzenRequiredValidator Component="RecoveryCode" Text="Recovery code is required" />
                        </RadzenStack>
                    </RadzenStack>

                    <div class="login-action-row">
                        <RadzenButton ButtonType="ButtonType.Submit"
                                      Text="Log in"
                                      ButtonStyle="ButtonStyle.Primary"
                                      IsBusy=@isProcessing
                                      BusyText="Verifying..." />

                        <RadzenLink Path="/Account/LoginWith2fa" Text="Use an authenticator code instead" />
                    </div>

                </RadzenStack>
            </RadzenTemplateForm>

        </RadzenStack>
    </div>
</RadzenCard>

@code {
    private InputModel Input { get; set; } = new();
    private bool isProcessing;

    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    [SupplyParameterFromQuery]
    private string? Error { get; set; }

    protected override void OnInitialized()
    {
        if (Error == "invalid")
        {
            NotificationService.Notify(NotificationSeverity.Error, "Recovery Code Error", "Invalid recovery code entered.");
        }
    }

    private async Task OnSubmitAsync(InputModel model)
    {
        isProcessing = true;

        try
        {
            var key = Guid.NewGuid();
            CookieLoginMiddleware.RecoveryCodeLogins[key] = new RecoveryCodeLoginInfo
            {
                Code = model.RecoveryCode,
                ReturnUrl = ReturnUrl,
            };
            NavigationManager.NavigateTo($"/loginrecovery?key={key}", forceLoad: true);
        }
        finally
        {
            isProcessing = false;
        }
    }

    private sealed class InputModel
    {
        [Required]
        public string RecoveryCode { get; set; } = "";
    }
}
