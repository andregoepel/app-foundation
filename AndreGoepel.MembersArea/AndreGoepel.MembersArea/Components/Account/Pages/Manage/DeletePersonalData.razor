@page "/Account/Manage/DeletePersonalData"
@rendermode InteractiveServer

@using System.ComponentModel.DataAnnotations
@using AndreGoepel.Marten.Identity.Users
@using AndreGoepel.MembersArea
@using Microsoft.AspNetCore.Identity
@using Radzen
@using Radzen.Blazor

@inject AuthenticationStateProvider AuthenticationStateProvider
@inject UserManager<User> UserManager
@inject SignInManager<User> SignInManager
@inject IdentityRedirectManager RedirectManager
@inject ILogger<DeletePersonalData> Logger

<PageTitle>Delete Personal Data</PageTitle>

<RadzenStack class="rz-p-0 rz-p-md-6">
    <RadzenHeading Text="Delete personal data" />

    <RadzenAlert AlertStyle=@MessageStyle Variant="Variant.Flat" Shade="Shade.Lighter" @bind-Visible="MessageVisible">
        @Message
    </RadzenAlert>

    <RadzenAlert 
        Text="Deleting this data will permanently remove your account, and this cannot be recovered."
        AlertStyle="AlertStyle.Warning"
        AllowClose="false" />

    <RadzenTemplateForm TItem="InputModel" Data=@Model Submit=@Submit>
        <RadzenStack>
            <RadzenRow AlignItems="AlignItems.Center" RowGap="0.25rem">
                <RadzenColumn Size="2">
                    <RadzenLabel Text="Enter password for confirmation" Component="Password" />
                </RadzenColumn>
                <RadzenColumn Size="3">
                    <RadzenPassword @bind-Value="Model.Password" Name="Password" Placeholder="Please enter your password." Style="display: block; width: 100%" />
                </RadzenColumn>
            </RadzenRow>
            <RadzenRow AlignItems="AlignItems.Center" RowGap="0.25rem">
                <RadzenRequiredValidator Component="Password" Text="Password is required" Style="position: absolute" />
            </RadzenRow>
        </RadzenStack>

        <RadzenButton ButtonType="ButtonType.Submit" Text="Delete data and close my account" />
    </RadzenTemplateForm>
</RadzenStack>

@code {
    private User? User;

    private string? Message;
    private AlertStyle MessageStyle = AlertStyle.Success;
    private bool MessageVisible;

    private InputModel Model { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        User = await UserManager.GetUserAsync(authState.User);
        if (User is null)
        {
            ShowMessage("Invalid user recognized", AlertStyle.Danger);
            return;
        }
    }

    private async Task Submit(InputModel model)
    {
        if (User is null)
        {
            ShowMessage("Invalid user recognized", AlertStyle.Danger);
            return;
        }

        if (!await UserManager.CheckPasswordAsync(User, Model.Password))
        {
            ShowMessage("Incorrect password.", AlertStyle.Danger);
            return;
        }

        var result = await UserManager.DeleteAsync(User);
        if (!result.Succeeded)
        {
            throw new InvalidOperationException("Unexpected error occurred deleting user.");
        }

        await SignInManager.SignOutAsync();

        var userId = await UserManager.GetUserIdAsync(User);
        Logger.LogInformation("User with ID '{UserId}' deleted themselves.", userId);

        RedirectManager.RedirectToCurrentPage();
    }

    private void ShowMessage(string message, AlertStyle style)
    {
        Message = message;
        MessageStyle = style;
        MessageVisible = true;
    }

    private sealed class InputModel
    {
        [DataType(DataType.Password)]
        public string Password { get; set; } = "";
    }
}
