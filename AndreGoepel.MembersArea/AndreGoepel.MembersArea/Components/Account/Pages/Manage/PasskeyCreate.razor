@page "/Account/Manage/Passkeys/Create"

@using AndreGoepel.Marten.Identity.Users
@using Microsoft.AspNetCore.Identity
@using Radzen
@using System.Buffers.Text
@using Radzen.Blazor

@inject AuthenticationStateProvider AuthenticationStateProvider
@inject SignInManager<User> SignInManager
@inject NavigationManager NavigationManager
@inject UserManager<User> UserManager
@inject NotificationService NotificationService

<PageTitle>Create a new Passkey</PageTitle>

<RadzenStack class="rz-p-0 rz-p-md-6">
    <RadzenHeading Text="Create a new Passkey" />

    <p>
        To create a new passkey please click on the button and follow the instructions of your browser
    </p>

    <form @formname="add-passkey" @onsubmit="AddPasskey" method="post">
        <AntiforgeryToken />
        <PasskeySubmit Operation="PasskeyOperation.Create"
                       Name="Input"
                       class="rz-button rz-button-md rz-variant-filled rz-primary rz-shade-default">
            Add a new passkey
        </PasskeySubmit>
    </form>
</RadzenStack>

@code {
    [SupplyParameterFromForm(FormName = "add-passkey")]
    private PasskeyInputModel Input { get; set; } = new();

    public User? User { get; set; }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync(); 
        User = await UserManager.GetUserAsync(authState.User);

    }

    private async Task AddPasskey()
    {
        if (User is null)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Error", "Invalid user recognized");
            return;
        }

        if (!string.IsNullOrEmpty(Input.Error))
        {
            NotificationService.Notify(NotificationSeverity.Error, "Error", Input.Error);
            return;
        }

        if (string.IsNullOrEmpty(Input.CredentialJson))
        {
            NotificationService.Notify(NotificationSeverity.Error, "Error", "The browser did not provide a passkey.");
            return;
        }

        var attestationResult = await SignInManager.PerformPasskeyAttestationAsync(Input.CredentialJson);
        if (!attestationResult.Succeeded)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Error", $"Could not add the passkey: {attestationResult.Failure.Message}");
            return;
        }

        var addPasskeyResult = await UserManager.AddOrUpdatePasskeyAsync(User, attestationResult.Passkey);
        if (!addPasskeyResult.Succeeded)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Error", "The passkey could not be added to your account.");
            return;
        }

        // Immediately prompt the user to enter a name for the credential
        var credentialIdBase64Url = Base64Url.EncodeToString(attestationResult.Passkey.CredentialId);
        NavigationManager.NavigateTo($"Account/Manage/RenamePasskey/{credentialIdBase64Url}");
    }
}