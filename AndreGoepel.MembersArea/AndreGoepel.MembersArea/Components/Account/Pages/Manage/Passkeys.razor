@page "/Account/Manage/Passkeys"
@rendermode InteractiveServer

@using System.Buffers.Text
@using System.ComponentModel.DataAnnotations
@using AndreGoepel.Marten.Identity.Users
@using AndreGoepel.MembersArea
@using Microsoft.AspNetCore.Identity
@using Radzen
@using Radzen.Blazor

@inject AuthenticationStateProvider AuthenticationStateProvider
@inject UserManager<User> UserManager
@inject NavigationManager NavigationManager
@inject DialogService DialogService

<PageTitle>Manage your passkeys</PageTitle>

<RadzenStack class="rz-p-0 rz-p-md-6">
    <RadzenHeading Text="Manage your Passkeys" />

    <RadzenAlert AlertStyle=@MessageStyle Variant="Variant.Flat" Shade="Shade.Lighter" @bind-Visible="MessageVisible">
        @Message
    </RadzenAlert>

    @if (currentPasskeys is { Count: > 0 })
    {
        <RadzenDataGrid Data="@currentPasskeys"
                        PageSize="10"
                        AllowPaging="true"
                        PagerHorizontalAlign="HorizontalAlign.Left"
                        ShowPagingSummary="true">
            <Columns>
                <RadzenDataGridColumn Property="@nameof(UserPasskeyInfo.Name)" Title="Name" Sortable="false" Filterable="false" />
                <RadzenDataGridColumn Title="Actions" Sortable="false" Filterable="false">
                    <Template Context="data">
                        <RadzenButton Text="Rename" Click="@(() => RenamePasskey(data))" />
                        <RadzenButton Text="Delete" Click="@(() => DeletePasskey(data))" />
                    </Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    }
    else
    {
        <RadzenAlert AlertStyle="AlertStyle.Info" AllowClose="false" Text="No passkeys are registered." />
    }

    @if (currentPasskeys is { Count: >= MaxPasskeyCount })
    {
        <RadzenAlert 
            AlertStyle="AlertStyle.Danger" 
            AllowClose="false" 
            Text="You have reached the maximum number of allowed passkeys. Please delete one before adding a new one." />                
    }
    else
    {
        <RadzenButton 
            Text="Add new passkey" 
            Click="@(() => NavigationManager.NavigateTo("/Account/Manage/Passkeys/Create"))" />                
    }

</RadzenStack>

@code {
    private const int MaxPasskeyCount = 100;

    private string? Message;
    private AlertStyle MessageStyle = AlertStyle.Success;
    private bool MessageVisible;

    private User? User;
    private IList<UserPasskeyInfo>? currentPasskeys;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        User = await UserManager.GetUserAsync(authState.User);

        if (User is null)
        {
            ShowMessage("Invalid user recognized", AlertStyle.Danger);
            return;
        }
        currentPasskeys = await UserManager.GetPasskeysAsync(User);
    }

    private async Task RenamePasskey(UserPasskeyInfo passkeyInfo)
    {
        var credentialIdBase64Url = Base64Url.EncodeToString(passkeyInfo.CredentialId);
        NavigationManager.NavigateTo($"Account/Manage/RenamePasskey/{credentialIdBase64Url}");
    }

    private async Task DeletePasskey(UserPasskeyInfo passkeyInfo)
    {
        if (User is null)
        {
            ShowMessage("Invalid user recognized", AlertStyle.Danger);
            return;
        }

        var dialogResult = await DialogService.Confirm($"Do you want to delete the passkey '{passkeyInfo.Name}'", "Delete passkey");

        if (dialogResult is not true)
            return;

        var result = await UserManager.RemovePasskeyAsync(User, passkeyInfo.CredentialId);
        if (!result.Succeeded)
        {
            ShowMessage("The passkey could not be deleted.", AlertStyle.Danger);
            return;
        }

        ShowMessage("Passkey deleted successfully.", AlertStyle.Success);

        currentPasskeys = await UserManager.GetPasskeysAsync(User);
    }

    private void ShowMessage(string message, AlertStyle style)
    {
        Message = message;
        MessageStyle = style;
        MessageVisible = true;
    }
}
