@page "/Account/Manage/RenamePasskey/{Id}"
@rendermode InteractiveServer

@using System.Buffers.Text
@using System.ComponentModel.DataAnnotations
@using AndreGoepel.Marten.Identity.Users
@using AndreGoepel.MembersArea
@using Microsoft.AspNetCore.Identity
@using Radzen
@using Radzen.Blazor

@inject AuthenticationStateProvider AuthenticationStateProvider
@inject UserManager<User> UserManager
@inject IdentityRedirectManager RedirectManager
@inject NavigationManager NavigationManager
@inject NotificationService NotificationService

<PageTitle>Passkey Name</PageTitle>

<RadzenStack class="rz-p-0 rz-p-md-6">
    @if (passkey?.Name is { } name)
    {
        <RadzenHeading Text="Change passkey name" />
    }
    else
    {
        <RadzenHeading Text="Add name for passkey" />
    }

    <RadzenTemplateForm TItem=RenamePasskeyModel Data=@Input Submit=@Rename>
        <RadzenStack>
            <RadzenRow AlignItems="AlignItems.Center" RowGap="0.25rem">
                <RadzenColumn Size="2">
                    <RadzenLabel Text="Passkey name" Component="PasskeyName" />
                </RadzenColumn>
                <RadzenColumn Size="3">
                    <RadzenTextBox @bind-Value="Input.Name" Name="PasskeyName" Style="display: block; width: 100%" />
                    <RadzenRequiredValidator Component="PasskeyName" Text="Name is required" Style="position: absolute" />
                    <RadzenLengthValidator Component="PasskeyName" Min="3" Max="100" Text="Passkey names must be at least 3 and no longer than 100 characters." />
                </RadzenColumn>
            </RadzenRow>

            <RadzenRow>
                <RadzenColumn>
                    <RadzenButton ButtonType="ButtonType.Submit" Text="Continue" />
                </RadzenColumn>
            </RadzenRow>
        </RadzenStack>
    </RadzenTemplateForm>
</RadzenStack>

@code {
    private User? user;
    private UserPasskeyInfo? passkey;

    [Parameter]
    public string? Id { get; set; }

    private RenamePasskeyModel Input { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();

        user = (await UserManager.GetUserAsync(authState.User))!;
        if (user is null)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Error", "Invalid user recognized");
            return;
        }

        byte[] credentialId;
        try
        {
            credentialId = Base64Url.DecodeFromChars(Id);
        }
        catch (FormatException)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Error", "The specified passkey ID had an invalid format.");
            return;
        }

        passkey = await UserManager.GetPasskeyAsync(user, credentialId);
        if (passkey is null)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Error", "The specified passkey could not be found.");
            return;
        }
    }

    private async Task Rename(RenamePasskeyModel model)
    {
        passkey!.Name = model.Name;
        var result = await UserManager.AddOrUpdatePasskeyAsync(user!, passkey);
        if (!result.Succeeded)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Error", "An error occurred while updating the passkey.");
            return;
        }

        NotificationService.Notify(NotificationSeverity.Success, "Success", "Passkey updated successfully.");
        NavigationManager.NavigateTo("Account/Manage/Passkeys");
    }

    private sealed class RenamePasskeyModel
    {
        public string Name { get; set; } = "";
    }
}
