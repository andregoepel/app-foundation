@page "/Account/Manage/ResetAuthenticator"
@rendermode InteractiveServer

@using AndreGoepel.Marten.Identity.Users
@using AndreGoepel.MembersArea
@using Microsoft.AspNetCore.Identity
@using Radzen
@using Radzen.Blazor

@inject UserManager<User> UserManager
@inject SignInManager<User> SignInManager
@inject IdentityRedirectManager RedirectManager
@inject NavigationManager NavigationManager
@inject ILogger<ResetAuthenticator> Logger

<PageTitle>Reset Authenticator Key – nerdventures.blog</PageTitle>

<div class="rz-p-4 rz-p-md-8">
    <RadzenCard>
        <RadzenStack Orientation="Orientation.Vertical" Gap="2rem" AlignItems="AlignItems.Stretch">

            <!-- Header (same style as Setup.razor) -->
            <div class="text-center">
                <RadzenText TextStyle="TextStyle.H3" TagName="TagName.H1">
                    Reset Authenticator Key
                </RadzenText>
                <RadzenText TextStyle="TextStyle.Body1" class="rz-color-muted mt-2">
                    Remove current authenticator app and start setup again
                </RadzenText>
            </div>

            <!-- Warning (prominent, danger style) -->
            <RadzenAlert AlertStyle="AlertStyle.Danger" Icon="warning" AllowClose="false">
                <div class="font-medium">
                    Resetting your authenticator key will make your current app stop working.
                </div>
                <div class="mt-2">
                    You will need to set up your authenticator app again immediately after this step.
                    <strong>If you do not complete the setup, you may lose access to your account.</strong>
                </div>
            </RadzenAlert>

            <!-- Action area -->
            <RadzenStack Gap="1.5rem" AlignItems="AlignItems.Center">

                <form method="post" action="/Account/Manage/ResetAuthenticator/ConfirmReset">
                    <AntiforgeryToken />

                    <RadzenButton ButtonType="ButtonType.Submit"
                                  Text="Reset Authenticator Key"
                                  ButtonStyle="ButtonStyle.Danger"
                                  Size="ButtonSize.Large"
                                  Icon="restart_alt" />
                </form>

                <RadzenButton Text="Cancel – Keep current setup"
                              ButtonStyle="ButtonStyle.Secondary"
                              Size="ButtonSize.Large"
                              Click="@(() => NavigationManager.NavigateTo("/Account/Manage/TwoFactorAuthentication"))" />
            </RadzenStack>

        </RadzenStack>
    </RadzenCard>
</div>

@code {
    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    private async Task OnSubmitAsync()
    {
        var user = await UserManager.GetUserAsync(HttpContext.User);
        if (user is null)
        {
            RedirectManager.RedirectToInvalidUser(UserManager, HttpContext);
            return;
        }

        await UserManager.SetTwoFactorEnabledAsync(user, false);
        await UserManager.ResetAuthenticatorKeyAsync(user);
        var userId = await UserManager.GetUserIdAsync(user);
        Logger.LogInformation("User with ID '{UserId}' has reset their authentication app key.", userId);

        await SignInManager.RefreshSignInAsync(user);

        RedirectManager.RedirectToWithStatus(
            "Account/Manage/EnableAuthenticator",
            "Authenticator reset",
            "Your authenticator app key has been reset, you will need to configure your authenticator app using the new key.");
    }
}
