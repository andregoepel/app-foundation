@page "/Administration/Roles"
@rendermode InteractiveServer

@using AndreGoepel.Marten.Identity.Roles
@using AndreGoepel.MembersArea.Components.Administration.Dialogs
@using Microsoft.AspNetCore.Authorization
@using System.Security.Claims

@using AndreGoepel.Marten.Identity.Users
@using Microsoft.AspNetCore.Identity
@using Radzen
@using Radzen.Blazor

@inject RoleManager<Role> RoleManager
@inject UserManager<User> UserManager
@inject DialogService DialogService

@attribute [Authorize(Roles = "Administrator")]

<PageTitle>Roles</PageTitle>

<h1>Roles</h1>

<RadzenDataGrid 
    Data="@roles" 
    AllowFiltering="true"
    AllowColumnResize="true"
    AllowAlternatingRows="false"
    FilterMode="FilterMode.Advanced"
    AllowSorting="true"
    PageSize="5"
    AllowPaging="true"
    PagerHorizontalAlign="HorizontalAlign.Left"
    ShowPagingSummary="true"
    LogicalFilterOperator="LogicalFilterOperator.Or"
    SelectionMode="DataGridSelectionMode.Single"
    @bind-Value="@selectedRoles">
    <Columns>
        <RadzenDataGridColumn Property="@nameof(Role.Id)" Title="Id" Sortable="false" Filterable="false"/>
        <RadzenDataGridColumn Property="@nameof(Role.Name)" Title="Name"/>
        <RadzenDataGridColumn Property="@nameof(Role.CreatedAt)" FormatString="{0:d} {0:t}" Title="Created at" />
        <RadzenDataGridColumn Property="@nameof(Role.ChangedAt)" FormatString="{0:d} {0:t}" Title="Changed at" />
        <RadzenDataGridColumn Property="@nameof(Role.Deleted)" Title="Deleted" />
        <RadzenDataGridColumn Title="Actions" Sortable="false" Filterable="false">
            <Template Context="data">
                @if (!data.Deleted)
                {
                    <RadzenButton Text="Users" Click="@(() => ShowUsers(data))" />
                }

                @if(data.Deletable && !data.Deleted)
                {
                    <RadzenButton Text="Delete" Click="@(() => DeleteRole(data))" />
                }
            </Template>
        </RadzenDataGridColumn>
    </Columns>
</RadzenDataGrid>

@code {
    private IQueryable<Role> roles = default!;
    private IList<Role> selectedRoles = [];

    private async Task ShowUsers(Role role)
    {
        if (string.IsNullOrWhiteSpace(role.Name))
            return;

        var users = await UserManager.GetUsersInRoleAsync(role.Name);

        await DialogService.OpenAsync<RoleUserDialog>("Edit Role Users", new Dictionary<string, object>() { { "RoleId", role.Id } });
    }

    private async Task DeleteRole(Role role)
    {
        if (await DialogService.Confirm("Are you sure you want to delete this role?", "Delete Role") == true)
        { 
            var deleteResult = await RoleManager.DeleteAsync(role);
            if (deleteResult.Succeeded)
                roles = RoleManager.Roles;
            else
                await DialogService.Alert("Role could not be deleted", "Error");
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        
        roles = RoleManager.Roles;
    }
}