@rendermode InteractiveServer

@using Radzen
@using Radzen.Blazor

@inject IJSRuntime JSRuntime

<RadzenStack Orientation="Orientation.Horizontal"
             AlignItems="AlignItems.Center"
             JustifyContent="JustifyContent.SpaceBetween"
             Style="width: 100%; padding: 0 0.5rem 0 0;">

    <RadzenButton Icon="menu"
                  Variant="Variant.Text"
                  ButtonStyle="ButtonStyle.Base"
                  Click="@ToggleSidebar" />

    <AuthorizeView>
        <Authorized>
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.75rem">

                <RadzenText TextStyle="TextStyle.Body2" Style="margin: 0; font-weight: 600;">@context.User.Identity?.Name</RadzenText>

                <form action="Account/Logout" method="post" name="header-logout-form">
                    <AntiforgeryToken />
                    <input type="hidden" name="ReturnUrl" value="/" />
                </form>

                <RadzenProfileMenu>
                    <RadzenProfileMenuItem Text="Profile"
                                           Path="Account/Manage/Profile"
                                           Icon="manage_accounts" />
                    <RadzenProfileMenuItem Text="Logout"
                                           Icon="power_settings_new"
                                           Path="javascript:document.forms['header-logout-form'].submit();" />
                </RadzenProfileMenu>

            </RadzenStack>
        </Authorized>
    </AuthorizeView>

</RadzenStack>

@code {
    private async Task ToggleSidebar()
    {
        await JSRuntime.InvokeVoidAsync("document.body.classList.toggle", "sidebar-collapsed");
    }
}
