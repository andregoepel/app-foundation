@page "/Administration/EmailSettings"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Administrator")]
@inherits AndreGoepel.AppFoundation.Components.LocalizedComponentBase

@using AndreGoepel.AppFoundation.MailService

@inject IEmailSettingsStore SettingsStore
@inject IEmailSender EmailSender
@inject NotificationService NotificationService

<AppPageTitle Title="@T("EmailSettings.PageTitle")" Breadcrumb="@T("EmailSettings.Breadcrumb")" />

<div class="rz-p-4 rz-p-md-6">
    <RadzenStack Gap="1.5rem">

        <PageHeader Title="@T("EmailSettings.PageTitle")" Subtitle="@T("EmailSettings.Subtitle")" />

        <RadzenCard>
            <RadzenTemplateForm TItem="InputModel" Data=@Input Submit=@OnValidSubmit>
                <RadzenStack Gap="1.25rem">

                    <div class="ag-form-grid">
                        <FormField Label="@T("EmailSettings.SenderNameLabel")" For="SenderName">
                            <RadzenTextBox @bind-Value=@Input.SenderName Name="SenderName" Style="width:100%" />
                            <RadzenRequiredValidator Component="SenderName" Text="@T("EmailSettings.SenderNameRequired")" />
                        </FormField>

                        <FormField Label="@T("EmailSettings.SenderEmailLabel")" For="SenderEmail">
                            <RadzenTextBox @bind-Value=@Input.SenderEmail Name="SenderEmail" Style="width:100%" />
                            <RadzenRequiredValidator Component="SenderEmail" Text="@T("EmailSettings.SenderEmailRequired")" />
                            <RadzenEmailValidator Component="SenderEmail" Text="@T("EmailSettings.SenderEmailInvalid")" />
                        </FormField>

                        <FormField Label="@T("EmailSettings.ServerLabel")" For="Server">
                            <RadzenTextBox @bind-Value=@Input.Server Name="Server" Style="width:100%" />
                            <RadzenRequiredValidator Component="Server" Text="@T("EmailSettings.ServerRequired")" />
                        </FormField>

                        <FormField Label="@T("EmailSettings.PortLabel")" For="Port">
                            <RadzenNumeric TValue="int" @bind-Value=@Input.Port Name="Port" Min="1" Max="65535" Style="width:120px" />
                        </FormField>

                        <FormField Label="@T("EmailSettings.UsernameLabel")" For="Username">
                            <RadzenTextBox @bind-Value=@Input.Username Name="Username" Style="width:100%" />
                            <RadzenRequiredValidator Component="Username" Text="@T("EmailSettings.UsernameRequired")" />
                        </FormField>

                        <FormField Label="@T("EmailSettings.PasswordLabel")" For="Password">
                            <RadzenPassword @bind-Value=@Input.Password
                                            Name="Password"
                                            Placeholder="@(hasPassword ? T("EmailSettings.PasswordPlaceholder") : "")"
                                            autocomplete="new-password"
                                            Style="width:100%" />
                            @if (!hasPassword)
                            {
                                <RadzenRequiredValidator Component="Password" Text="@T("EmailSettings.PasswordRequired")" />
                            }
                        </FormField>
                    </div>

                    <RadzenStack Orientation="Orientation.Horizontal" Gap="2rem" AlignItems="AlignItems.Center">
                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.6rem">
                            <RadzenSwitch @bind-Value=@Input.UseSsl Name="UseSsl" />
                            <RadzenLabel Text="@T("EmailSettings.UseSslLabel")" Component="UseSsl" />
                        </RadzenStack>
                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.6rem">
                            <RadzenSwitch @bind-Value=@Input.Html Name="Html" />
                            <RadzenLabel Text="@T("EmailSettings.HtmlEmailsLabel")" Component="Html" />
                        </RadzenStack>
                    </RadzenStack>

                    <div class="ag-card-actions">
                        <RadzenButton ButtonType="ButtonType.Button"
                                      Text="@T("EmailSettings.DiscardButton")"
                                      ButtonStyle="ButtonStyle.Light"
                                      Click=@OnDiscard
                                      Disabled=@isSaving />
                        <RadzenButton ButtonType="ButtonType.Submit"
                                      Text="@T("EmailSettings.SaveButton")"
                                      ButtonStyle="ButtonStyle.Primary"
                                      IsBusy=@isSaving
                                      BusyText="@T("EmailSettings.SavingBusyText")" />
                    </div>

                </RadzenStack>
            </RadzenTemplateForm>
        </RadzenCard>

        <RadzenCard>
            <RadzenStack Gap="1rem">
                <div>
                    <RadzenText TextStyle="TextStyle.H6">@T("EmailSettings.SendTestEmailTitle")</RadzenText>
                    <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--rz-text-secondary-color);">
                        @T("EmailSettings.SendTestEmailCaption")
                    </RadzenText>
                </div>
                <RadzenStack Orientation="Orientation.Horizontal" Gap="0.75rem" AlignItems="AlignItems.Center">
                    <RadzenTextBox @bind-Value=@testRecipient
                                   Name="TestRecipient"
                                   Placeholder="recipient@example.com"
                                   Style="flex: 1;" />
                    <RadzenButton Text="@T("EmailSettings.SendTestButton")"
                                  ButtonStyle="ButtonStyle.Light"
                                  Click=@OnSendTest
                                  IsBusy=@isSendingTest
                                  BusyText="@T("EmailSettings.SendingBusyText")"
                                  Disabled=@string.IsNullOrWhiteSpace(testRecipient) />
                </RadzenStack>
            </RadzenStack>
        </RadzenCard>

    </RadzenStack>
</div>

@code {
    private InputModel Input { get; set; } = new();
    private bool hasPassword;
    private bool isSaving;
    private bool isSendingTest;
    private string testRecipient = "";

    protected override Task OnInitializedAsync() => LoadSettingsAsync();

    private async Task LoadSettingsAsync()
    {
        var settings = await SettingsStore.LoadAsync();
        hasPassword = settings.HasPassword;
        Input = new InputModel
        {
            SenderName = settings.SenderName,
            SenderEmail = settings.SenderEmail,
            Server = settings.Server,
            Port = settings.Port,
            UseSsl = settings.UseSsl,
            Username = settings.Username,
            Html = settings.Html,
        };
    }

    // Discard: reload the persisted settings, dropping any unsaved edits.
    private Task OnDiscard() => LoadSettingsAsync();

    private async Task OnValidSubmit(InputModel model)
    {
        isSaving = true;
        try
        {
            await SettingsStore.SaveAsync(
                new EmailSettings
                {
                    SenderName = model.SenderName,
                    SenderEmail = model.SenderEmail,
                    Server = model.Server,
                    Port = model.Port,
                    UseSsl = model.UseSsl,
                    Username = model.Username,
                    Html = model.Html,
                },
                string.IsNullOrEmpty(model.Password) ? null : model.Password
            );

            hasPassword = true;
            Input.Password = "";
            NotificationService.Notify(
                NotificationSeverity.Success,
                T("EmailSettings.SavedNotificationTitle"),
                T("EmailSettings.SavedNotificationMessage")
            );
        }
        catch (Exception ex)
        {
            NotificationService.Notify(
                NotificationSeverity.Error,
                T("EmailSettings.ErrorSavingSettingsTitle"),
                ex.Message
            );
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task OnSendTest()
    {
        isSendingTest = true;
        try
        {
            await EmailSender.SendAsync(
                testRecipient,
                T("EmailSettings.TestEmailSubject"),
                T("EmailSettings.TestEmailBody")
            );
            NotificationService.Notify(
                NotificationSeverity.Success,
                T("EmailSettings.TestEmailSentTitle"),
                T("EmailSettings.TestEmailSentMessage", testRecipient)
            );
        }
        catch (Exception ex)
        {
            NotificationService.Notify(
                NotificationSeverity.Error,
                T("EmailSettings.TestEmailFailedTitle"),
                ex.Message
            );
        }
        finally
        {
            isSendingTest = false;
        }
    }

    private sealed class InputModel
    {
        [Required]
        public string SenderName { get; set; } = "";

        [Required]
        [EmailAddress]
        public string SenderEmail { get; set; } = "";

        [Required]
        public string Server { get; set; } = "";

        public int Port { get; set; } = 587;

        public bool UseSsl { get; set; }

        [Required]
        public string Username { get; set; } = "";

        public string Password { get; set; } = "";

        public bool Html { get; set; } = true;
    }
}
