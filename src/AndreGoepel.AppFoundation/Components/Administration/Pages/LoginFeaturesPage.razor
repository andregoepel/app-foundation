@page "/Administration/LoginFeatures"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Administrator")]
@inherits AndreGoepel.AppFoundation.Components.LocalizedComponentBase

@using AndreGoepel.AppFoundation.Identity

@inject IIdentityFeatureSettingsStore SettingsStore
@inject NotificationService NotificationService

<AppPageTitle Title="@T("LoginFeatures.PageTitle")" Breadcrumb="@T("LoginFeatures.Breadcrumb")" />

<div class="rz-p-4 rz-p-md-6">
    <RadzenStack Gap="1.5rem">

        <div>
            <RadzenText TextStyle="TextStyle.H5" TagName="TagName.H1">@T("LoginFeatures.PageTitle")</RadzenText>
            <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-secondary-color);">
                @T("LoginFeatures.Subtitle")
            </RadzenText>
        </div>

        @if (loadedFromConfiguration)
        {
            <RadzenAlert AlertStyle="AlertStyle.Info" ShowIcon="true" AllowClose="false">
                @T("LoginFeatures.ConfigFromCodeAlert")
            </RadzenAlert>
        }

        <RadzenCard>
            <RadzenTemplateForm TItem="InputModel" Data=@Input Submit=@OnValidSubmit>
                <RadzenStack Gap="0">

                    <SettingToggleRow Label="@T("LoginFeatures.SelfServiceRegistrationLabel")"
                                       Description="@T("LoginFeatures.SelfServiceRegistrationDescription")"
                                       @bind-Value=@Input.EnableUserRegistration />

                    <SettingToggleRow Label="@T("LoginFeatures.TwoFactorLabel")"
                                       Description="@T("LoginFeatures.TwoFactorDescription")"
                                       @bind-Value=@Input.EnableTwoFactor />

                    <SettingToggleRow Label="@T("LoginFeatures.PasskeysLabel")"
                                       Description="@T("LoginFeatures.PasskeysDescription")"
                                       @bind-Value=@Input.EnablePasskey />

                    <div class="ag-card-actions">
                        <RadzenButton ButtonType="ButtonType.Submit"
                                      Text="@T("LoginFeatures.SaveButton")"
                                      ButtonStyle="ButtonStyle.Primary"
                                      IsBusy=@isSaving
                                      BusyText="@T("LoginFeatures.SavingBusyText")" />
                    </div>

                </RadzenStack>
            </RadzenTemplateForm>
        </RadzenCard>

    </RadzenStack>
</div>

@code {
    private InputModel Input { get; set; } = new();
    private bool loadedFromConfiguration;
    private bool isSaving;

    protected override async Task OnInitializedAsync()
    {
        var settings = await SettingsStore.LoadAsync();
        loadedFromConfiguration = settings.FromConfiguration;
        Input = new InputModel
        {
            EnableUserRegistration = settings.EnableUserRegistration,
            EnableTwoFactor = settings.EnableTwoFactor,
            EnablePasskey = settings.EnablePasskey,
        };
    }

    private async Task OnValidSubmit(InputModel model)
    {
        isSaving = true;
        try
        {
            await SettingsStore.SaveAsync(
                new IdentityFeatureSettings
                {
                    EnableUserRegistration = model.EnableUserRegistration,
                    EnableTwoFactor = model.EnableTwoFactor,
                    EnablePasskey = model.EnablePasskey,
                }
            );

            loadedFromConfiguration = false;
            NotificationService.Notify(
                NotificationSeverity.Success,
                T("LoginFeatures.SavedNotificationTitle"),
                T("LoginFeatures.SavedNotificationMessage")
            );
        }
        catch (Exception ex)
        {
            NotificationService.Notify(
                NotificationSeverity.Error,
                T("LoginFeatures.ErrorSavingSettingsTitle"),
                ex.Message
            );
        }
        finally
        {
            isSaving = false;
        }
    }

    private sealed class InputModel
    {
        public bool EnableUserRegistration { get; set; } = true;

        public bool EnableTwoFactor { get; set; } = true;

        public bool EnablePasskey { get; set; } = true;
    }
}
