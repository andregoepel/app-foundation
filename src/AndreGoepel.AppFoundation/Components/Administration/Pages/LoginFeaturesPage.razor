@page "/Administration/LoginFeatures"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Administrator")]

@using AndreGoepel.AppFoundation.Identity

@inject IIdentityFeatureSettingsStore SettingsStore
@inject NotificationService NotificationService

<AppFoundationPageTitle Title="Login Features" Breadcrumb="Administration / Login Features" />

<div class="rz-p-4 rz-p-md-6">
    <RadzenStack Gap="1.5rem">

        <div>
            <RadzenText TextStyle="TextStyle.H5" TagName="TagName.H1">Login Features</RadzenText>
            <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-secondary-color);">
                Turn self-service sign-up and the optional sign-in methods on or off. A disabled
                feature is hidden here and made unreachable by direct URL.
            </RadzenText>
        </div>

        @if (loadedFromConfiguration)
        {
            <RadzenAlert AlertStyle="AlertStyle.Info" ShowIcon="true" AllowClose="false">
                These values come from the application's configuration baseline. Saving stores them
                in the database, which takes precedence from then on — no restart required.
            </RadzenAlert>
        }

        <RadzenCard Style="padding: 8px 30px;">
            <RadzenTemplateForm TItem="InputModel" Data=@Input Submit=@OnValidSubmit>

                <div style="display: flex; align-items: center; justify-content: space-between; gap: 24px; padding: 20px 0; border-bottom: 1px solid var(--rz-border-color);">
                    <div style="flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 3px;">
                        <span style="font: 600 15px 'Space Grotesk', system-ui, sans-serif; color: var(--rz-text-title-color);">Self-service registration</span>
                        <span style="font-size: 12.5px; color: var(--rz-text-secondary-color);">Lets visitors create their own account.</span>
                    </div>
                    <RadzenSwitch @bind-Value=@Input.EnableUserRegistration Name="EnableUserRegistration" />
                </div>

                <div style="display: flex; align-items: center; justify-content: space-between; gap: 24px; padding: 20px 0; border-bottom: 1px solid var(--rz-border-color);">
                    <div style="flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 3px;">
                        <span style="font: 600 15px 'Space Grotesk', system-ui, sans-serif; color: var(--rz-text-title-color);">Two-factor authentication</span>
                        <span style="font-size: 12.5px; color: var(--rz-text-secondary-color);">Authenticator-app setup. Users already enrolled can still complete sign-in.</span>
                    </div>
                    <RadzenSwitch @bind-Value=@Input.EnableTwoFactor Name="EnableTwoFactor" />
                </div>

                <div style="display: flex; align-items: center; justify-content: space-between; gap: 24px; padding: 20px 0; border-bottom: 1px solid var(--rz-border-color);">
                    <div style="flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 3px;">
                        <span style="font: 600 15px 'Space Grotesk', system-ui, sans-serif; color: var(--rz-text-title-color);">Passkeys</span>
                        <span style="font-size: 12.5px; color: var(--rz-text-secondary-color);">WebAuthn passkey registration and sign-in.</span>
                    </div>
                    <RadzenSwitch @bind-Value=@Input.EnablePasskey Name="EnablePasskey" />
                </div>

                <div style="display: flex; justify-content: flex-end; padding: 18px 0 20px;">
                    <RadzenButton ButtonType="ButtonType.Submit"
                                  Text="Save changes"
                                  ButtonStyle="ButtonStyle.Primary"
                                  IsBusy=@isSaving
                                  BusyText="Saving..." />
                </div>

            </RadzenTemplateForm>
        </RadzenCard>

    </RadzenStack>
</div>

@code {
    private InputModel Input { get; set; } = new();
    private bool loadedFromConfiguration;
    private bool isSaving;

    protected override async Task OnInitializedAsync()
    {
        var settings = await SettingsStore.LoadAsync();
        loadedFromConfiguration = settings.FromConfiguration;
        Input = new InputModel
        {
            EnableUserRegistration = settings.EnableUserRegistration,
            EnableTwoFactor = settings.EnableTwoFactor,
            EnablePasskey = settings.EnablePasskey,
        };
    }

    private async Task OnValidSubmit(InputModel model)
    {
        isSaving = true;
        try
        {
            await SettingsStore.SaveAsync(
                new IdentityFeatureSettings
                {
                    EnableUserRegistration = model.EnableUserRegistration,
                    EnableTwoFactor = model.EnableTwoFactor,
                    EnablePasskey = model.EnablePasskey,
                }
            );

            loadedFromConfiguration = false;
            NotificationService.Notify(
                NotificationSeverity.Success,
                "Saved",
                "Login features updated. Changes apply to the next request."
            );
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Error saving settings", ex.Message);
        }
        finally
        {
            isSaving = false;
        }
    }

    private sealed class InputModel
    {
        public bool EnableUserRegistration { get; set; } = true;

        public bool EnableTwoFactor { get; set; } = true;

        public bool EnablePasskey { get; set; } = true;
    }
}
