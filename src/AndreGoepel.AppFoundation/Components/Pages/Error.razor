@page "/Error"
@using System.Diagnostics
@inherits AndreGoepel.AppFoundation.Components.LocalizedComponentBase

<AppPageTitle Title="@T("Error.PageTitle")" />

<div class="rz-p-4 rz-p-md-6">
    <RadzenStack Gap="1.5rem">

        <div>
            <RadzenText TextStyle="TextStyle.H5" TagName="TagName.H1">@T("Error.PageTitle")</RadzenText>
            <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-secondary-color);">
                @T("Error.Message")
            </RadzenText>
        </div>

        @if (ShowRequestId)
        {
            <RadzenText TextStyle="TextStyle.Body2">
                <strong>@T("Error.RequestIdLabel")</strong> <code>@RequestId</code>
            </RadzenText>
        }

        <RadzenCard>
            <RadzenStack Gap="0.75rem">
                <RadzenText TextStyle="TextStyle.H6">@T("Error.DevModeTitle")</RadzenText>
                <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-secondary-color);">
                    @((MarkupString)T("Error.DevModeParagraph"))
                </RadzenText>
            </RadzenStack>
        </RadzenCard>

    </RadzenStack>
</div>

@code{
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
