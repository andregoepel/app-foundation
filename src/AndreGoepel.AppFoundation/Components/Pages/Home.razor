@page "/dashboard"
@attribute [Authorize]
@inherits AndreGoepel.AppFoundation.Components.LocalizedComponentBase

<AppPageTitle Title="@T("Home.PageTitle")" Breadcrumb="@T("Home.PageTitle")" />

<div class="rz-p-4 rz-p-md-6">
    <RadzenStack Gap="1.5rem">

        <RadzenText TextStyle="TextStyle.H5" TagName="TagName.H1">@T("Home.PageTitle")</RadzenText>

        <RadzenCard>
            <RadzenStack Gap="0.5rem">
                <RadzenText TextStyle="TextStyle.H6">@T("Home.Welcome")</RadzenText>
                <RadzenText TextStyle="TextStyle.Body1" Style="color: var(--rz-text-secondary-color);">
                    @T("Home.Description")
                </RadzenText>
            </RadzenStack>
        </RadzenCard>

    </RadzenStack>
</div>
