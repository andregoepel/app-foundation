@inject NavigationManager NavigationManager
@inherits LocalizedComponentBase

<AppPageTitle Title="@_copy.Title" />

<div class="rz-p-4 rz-p-md-8">
    <EmptyState Icon="🚫︎" Title="@_copy.Title" Text="@_copy.Message">
        <Actions>
            <RadzenButton Text="@T("Error.GoToHome")"
                          ButtonStyle="ButtonStyle.Primary"
                          Click=@(() => NavigationManager.NavigateTo("/")) />
        </Actions>
    </EmptyState>
</div>

@code {
    [Parameter, EditorRequired]
    public required string Code { get; set; }

    private ErrorCopy _copy = default!;

    protected override void OnParametersSet() =>
        _copy = Code switch
        {
            "403" => new ErrorCopy(T("Error.AccessDeniedTitle"), T("Error.AccessDeniedMessage")),
            _ => new ErrorCopy(T("Error.NotFoundTitle"), T("Error.NotFoundMessage")),
        };

    private record ErrorCopy(string Title, string Message);
}
