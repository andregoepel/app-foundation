@inject NavigationManager NavigationManager

<AppPageTitle Title="@_copy.Title" />

<div class="rz-p-4 rz-p-md-8">
    <EmptyState Icon="🚫︎" Title="@_copy.Title" Text="@_copy.Message">
        <Actions>
            <RadzenButton Text="Go to home"
                          ButtonStyle="ButtonStyle.Primary"
                          Click=@(() => NavigationManager.NavigateTo("/")) />
        </Actions>
    </EmptyState>
</div>

@code {
    [Parameter, EditorRequired]
    public required string Code { get; set; }

    private ErrorCopy _copy = default!;

    private static readonly Dictionary<string, ErrorCopy> Copies = new()
    {
        ["404"] = new("Page not found", "The page you’re looking for doesn’t exist or has moved."),
        ["403"] = new("Access denied", "You do not have permission to access this resource."),
    };

    protected override void OnParametersSet() =>
        _copy = Copies.GetValueOrDefault(Code, Copies["404"]);

    private record ErrorCopy(string Title, string Message);
}
