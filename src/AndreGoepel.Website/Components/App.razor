@using Radzen.Blazor
@using AndreGoepel.Website.Services
@inject NavigationManager NavigationManager
@inject IHttpContextAccessor HttpContextAccessor
@{
    var relativePath = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
    var path = relativePath.Split('?', '#')[0].Trim('/');
    var isLanding = string.IsNullOrEmpty(path);

    // The marketing landing page renders as static SSR (no Blazor circuit) for a fast,
    // flicker-free first paint. Everything else keeps the interactive server render mode.
    var lang = isLanding ? SiteLanguage.Resolve(HttpContextAccessor.HttpContext) : "en";
}
<!DOCTYPE html>
<html lang="@lang">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="@NavigationManager.BaseUri" />

    @if (isLanding)
    {
        <link rel="preload" as="font" type="font/woff2" crossorigin
              href="fonts/InterVariable.woff2" />
        <link rel="stylesheet" href="css/app.css" />
        <link rel="icon" type="image/png" href="favicon.png" />

        @* Critical CSS: only hide reveal elements when JS is present, so content is
           always visible without a script. Set before first paint. *@
        <style>html.js .reveal{opacity:0}.hero{min-height:100vh}</style>

        @* No-flash theme: apply the stored theme to <html> before the body paints. *@
        <script>
            (function () {
                var d = document.documentElement;
                d.classList.add('js');
                try {
                    var t = localStorage.getItem('ag-theme');
                    if (t !== 'light' && t !== 'dark' && t !== 'system') t = 'dark';
                    d.dataset.userTheme = t;
                    d.dataset.theme = t === 'system'
                        ? (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light')
                        : t;
                } catch (e) {
                    d.dataset.theme = 'dark';
                }
            })();
        </script>

        <HeadOutlet />
    }
    else
    {
        <RadzenTheme Theme="material" @rendermode="InteractiveServer" />

        <link rel="stylesheet" href="_content/AndreGoepel.AppFoundation/app.css" />
        <link rel="stylesheet" href="@Assets["AndreGoepel.Website.styles.css"]" />
        <link rel="icon" type="image/png" href="favicon.png" />

        <HeadOutlet @rendermode="InteractiveServer" />
    }
</head>

<body>
    @if (isLanding)
    {
        <Routes />
        <script src="js/site.js"></script>
        <script>document.addEventListener('DOMContentLoaded', function () { site.boot(); });</script>
    }
    else
    {
        <Routes @rendermode="InteractiveServer" />
        <script src="js/site.js"></script>
        <script src="@Assets["_framework/blazor.web.js"]"></script>
        <script src="_content/Radzen.Blazor/Radzen.Blazor.js"></script>
    }
</body>

</html>
