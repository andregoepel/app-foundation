<section id="cases" class="sec sec-cases">
    <div class="sec-inner">
        <div class="cases-head">
            <div>
                <div class="reveal kicker">@Cases.Kicker</div>
                <h2 class="reveal sec-title" style="transition-delay: 60ms">@Cases.Title</h2>
            </div>
            <div class="reveal cases-demo-flag" style="transition-delay: 120ms">
                <span class="cases-demo-dot"></span> @Cases.Demo
            </div>
        </div>
        <p class="reveal cases-note" style="transition-delay: 120ms">@Cases.Note</p>
        <div class="cases-list">
            @for (int i = 0; i < Cases.Items.Count; i++)
            {
                var c = Cases.Items[i];
                var num = i + 1;
                var delay = 160 + i * 100;
                <article class="reveal case-row" style="transition-delay: @(delay)ms">
                    <div class="case-num">0@(num)</div>
                    <div class="case-sector">@c.Sector</div>
                    <div class="case-title">@c.Title</div>
                    <div class="case-body">@c.Body</div>
                    <div class="case-result"><strong>→</strong> @c.Result</div>
                    <div class="case-stack">
                        @foreach (var chip in c.Stack)
                        {
                            <span class="case-chip">@chip</span>
                        }
                    </div>
                </article>
            }
        </div>
    </div>
</section>

@code {
    [Parameter]
    [EditorRequired]
    public required Cases Cases { get; set; }
}
