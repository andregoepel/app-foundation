<section id="top" class="hero">
    <div class="hero-bg" aria-hidden="true">
        <canvas id="hero-canvas" class="hero-bg-canvas"></canvas>
        <div class="hero-bg-vignette"></div>
    </div>

    <div class="circuit-deco" aria-hidden="true">
        <svg class="circuit-tr" viewBox="0 0 400 320" preserveAspectRatio="xMaxYMin meet">
            <polyline points="260,20 320,20 320,40 380,40" fill="none" stroke="currentColor" stroke-width="1" stroke-linejoin="miter" stroke-linecap="square" opacity="0.45" />
            <polyline points="200,60 260,60 260,80 340,80 340,100 400,100" fill="none" stroke="currentColor" stroke-width="1" stroke-linejoin="miter" stroke-linecap="square" opacity="0.35" />
            <polyline points="300,120 360,120 360,150 400,150" fill="none" stroke="currentColor" stroke-width="1" stroke-linejoin="miter" stroke-linecap="square" opacity="0.3" />
            <polyline points="240,180 280,180 280,210 360,210 360,240 400,240" fill="none" stroke="currentColor" stroke-width="1" stroke-linejoin="miter" stroke-linecap="square" opacity="0.4" />
            <polyline points="320,260 380,260 380,290 400,290" fill="none" stroke="currentColor" stroke-width="1" stroke-linejoin="miter" stroke-linecap="square" opacity="0.3" />
            <circle cx="380" cy="40" r="3" fill="currentColor" stroke="currentColor" stroke-width="1" opacity="0.9" />
            <circle cx="260" cy="60" r="2" fill="none" stroke="currentColor" stroke-width="1" opacity="0.6" />
            <circle cx="340" cy="80" r="2.5" fill="currentColor" stroke="currentColor" stroke-width="1" opacity="0.7" />
            <circle cx="360" cy="150" r="2" fill="none" stroke="currentColor" stroke-width="1" opacity="0.5" />
            <circle cx="280" cy="180" r="3" fill="currentColor" stroke="currentColor" stroke-width="1" opacity="0.8" />
            <circle cx="360" cy="210" r="2" fill="none" stroke="currentColor" stroke-width="1" opacity="0.6" />
            <circle cx="380" cy="290" r="2.5" fill="currentColor" stroke="currentColor" stroke-width="1" opacity="0.7" />
            <path d="M 380 60 L 400 60 L 400 200 L 360 200 Z" fill="currentColor" opacity="0.06" />
            <path d="M 360 200 L 400 200 L 400 240 Z" fill="currentColor" opacity="0.10" />
        </svg>
        <svg class="circuit-bl" viewBox="0 0 400 320" preserveAspectRatio="xMinYMax meet">
            <polyline points="0,40 40,40 40,80 80,80 80,60 120,60" fill="none" stroke="currentColor" stroke-width="1" stroke-linejoin="miter" stroke-linecap="square" opacity="0.35" />
            <polyline points="0,120 60,120 60,160 100,160" fill="none" stroke="currentColor" stroke-width="1" stroke-linejoin="miter" stroke-linecap="square" opacity="0.3" />
            <polyline points="0,200 80,200 80,240 140,240" fill="none" stroke="currentColor" stroke-width="1" stroke-linejoin="miter" stroke-linecap="square" opacity="0.4" />
            <polyline points="0,280 60,280 60,300 120,300 120,320" fill="none" stroke="currentColor" stroke-width="1" stroke-linejoin="miter" stroke-linecap="square" opacity="0.45" />
            <polyline points="20,0 20,40" fill="none" stroke="currentColor" stroke-width="1" stroke-linejoin="miter" stroke-linecap="square" opacity="0.3" />
            <circle cx="40" cy="40" r="2" fill="none" stroke="currentColor" stroke-width="1" opacity="0.6" />
            <circle cx="80" cy="60" r="2.5" fill="currentColor" stroke="currentColor" stroke-width="1" opacity="0.7" />
            <circle cx="120" cy="60" r="3" fill="currentColor" stroke="currentColor" stroke-width="1" opacity="0.9" />
            <circle cx="60" cy="160" r="2" fill="none" stroke="currentColor" stroke-width="1" opacity="0.5" />
            <circle cx="80" cy="240" r="2.5" fill="currentColor" stroke="currentColor" stroke-width="1" opacity="0.7" />
            <circle cx="140" cy="240" r="2" fill="currentColor" stroke="currentColor" stroke-width="1" opacity="0.8" />
            <circle cx="60" cy="280" r="2" fill="none" stroke="currentColor" stroke-width="1" opacity="0.5" />
            <path d="M 0 260 L 40 260 L 40 320 L 0 320 Z" fill="currentColor" opacity="0.06" />
        </svg>
    </div>

    <div class="hero-inner">
        <div class="reveal hero-eyebrow">
            <span class="hero-pulse"></span>
            @Hero.Eyebrow
        </div>
        <h1 class="reveal hero-title" style="transition-delay: 80ms">
            <span class="hero-title-line">@Hero.Title[0]</span>
            <span class="hero-title-line hero-title-line-2">@Hero.Title[1]</span>
        </h1>
        <p class="reveal hero-body" style="transition-delay: 180ms">@Hero.Body</p>
        <div class="reveal hero-actions" style="transition-delay: 260ms">
            <a href="#contact" class="btn btn-primary">
                <span>@Hero.Cta</span>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7" /></svg>
            </a>
            <a href="#services" class="btn btn-ghost">
                <span>@Hero.ServicesLabel</span>
            </a>
        </div>
        <div class="reveal hero-meta" style="transition-delay: 340ms">
            <span class="hero-meta-dot"></span>
            <span>@Hero.Meta</span>
        </div>
    </div>

    <div class="reveal hero-corners" aria-hidden="true">
        <span class="hero-corner hc-tl"></span>
        <span class="hero-corner hc-tr"></span>
        <span class="hero-corner hc-bl"></span>
        <span class="hero-corner hc-br"></span>
    </div>
</section>

@code {
    [Parameter]
    [EditorRequired]
    public required Hero Hero { get; set; }
}
