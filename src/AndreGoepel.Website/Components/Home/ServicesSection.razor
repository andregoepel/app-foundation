<section id="services" class="sec sec-services svc-layout-grid">
    <div class="sec-inner">
        <div class="reveal kicker">@Services.Kicker</div>
        <h2 class="reveal sec-title" style="transition-delay: 60ms">@Services.Title</h2>
        <div class="svc-grid">
            @for (int i = 0; i < Services.Items.Count; i++)
            {
                var svc = Services.Items[i];
                var num = i + 1;
                var delay = 120 + i * 90;
                <article class="reveal svc-card" style="transition-delay: @(delay)ms">
                    <div class="svc-card-top">
                        <span class="svc-num">0@(num)</span>
                        <span class="svc-tag">@svc.Tag</span>
                    </div>
                    <h3 class="svc-name">@svc.Name</h3>
                    <div class="svc-meta">@svc.Meta</div>
                    <p class="svc-body">@svc.Body</p>
                    <ul class="svc-bullets">
                        @foreach (var bullet in svc.Bullets)
                        {
                            <li><span class="svc-tick">✓</span>@bullet</li>
                        }
                    </ul>
                    <div class="svc-arrow" aria-hidden="true">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7" /></svg>
                    </div>
                </article>
            }
        </div>
    </div>
</section>

@code {
    [Parameter]
    [EditorRequired]
    public required Services Services { get; set; }
}
