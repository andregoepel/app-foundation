@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>@(_copy.Tag) · andregoepel.dev</PageTitle>

<header class="hdr is-scrolled">
    <a href="/" class="hdr-brand" aria-label="andregoepel.dev">
        <span class="hdr-mark">
            <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
                <circle cx="11" cy="11" r="10" stroke="currentColor" stroke-width="1.4" />
                <path d="M5 14 L11 5 L17 14" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
                <circle cx="11" cy="11" r="2.2" fill="var(--accent)" />
            </svg>
        </span>
        <span class="hdr-wordmark"><span>andregoepel</span><span class="hdr-tld">.dev</span></span>
    </a>
    <div class="hdr-tools">
        <div class="hdr-seg hdr-theme" role="group" aria-label="Theme">
            <button class="@(_theme == "light" ? "is-on" : "")" @onclick='() => SetTheme("light")' title="Light" aria-label="Light">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="4" /><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
                </svg>
            </button>
            <button class="@(_theme == "system" ? "is-on" : "")" @onclick='() => SetTheme("system")' title="System" aria-label="System">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="2" y="4" width="20" height="14" rx="2" /><path d="M8 22h8M12 18v4" />
                </svg>
            </button>
            <button class="@(_theme == "dark" ? "is-on" : "")" @onclick='() => SetTheme("dark")' title="Dark" aria-label="Dark">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
                </svg>
            </button>
        </div>
    </div>
</header>

<main>
    <section class="err">
        <div class="err-bg" aria-hidden="true">
            <canvas id="err-canvas"></canvas>
            <div class="hero-bg-vignette"></div>
        </div>

        <div class="circuit-deco" aria-hidden="true">
            <svg class="circuit-tr" viewBox="0 0 400 320" preserveAspectRatio="xMaxYMin meet">
                <polyline points="260,20 320,20 320,40 380,40" fill="none" stroke="currentColor" stroke-width="1" stroke-linejoin="miter" stroke-linecap="square" opacity="0.45" />
                <polyline points="200,60 260,60 260,80 340,80 340,100 400,100" fill="none" stroke="currentColor" stroke-width="1" stroke-linejoin="miter" stroke-linecap="square" opacity="0.35" />
                <polyline points="300,120 360,120 360,150 400,150" fill="none" stroke="currentColor" stroke-width="1" stroke-linejoin="miter" stroke-linecap="square" opacity="0.3" />
                <polyline points="240,180 280,180 280,210 360,210 360,240 400,240" fill="none" stroke="currentColor" stroke-width="1" stroke-linejoin="miter" stroke-linecap="square" opacity="0.4" />
                <polyline points="320,260 380,260 380,290 400,290" fill="none" stroke="currentColor" stroke-width="1" stroke-linejoin="miter" stroke-linecap="square" opacity="0.3" />
                <circle cx="380" cy="40" r="3" fill="currentColor" stroke="currentColor" stroke-width="1" opacity="0.9" />
                <circle cx="260" cy="60" r="2" fill="none" stroke="currentColor" stroke-width="1" opacity="0.6" />
                <circle cx="340" cy="80" r="2.5" fill="currentColor" stroke="currentColor" stroke-width="1" opacity="0.7" />
                <circle cx="360" cy="150" r="2" fill="none" stroke="currentColor" stroke-width="1" opacity="0.5" />
                <circle cx="280" cy="180" r="3" fill="currentColor" stroke="currentColor" stroke-width="1" opacity="0.8" />
                <circle cx="360" cy="210" r="2" fill="none" stroke="currentColor" stroke-width="1" opacity="0.6" />
                <circle cx="380" cy="290" r="2.5" fill="currentColor" stroke="currentColor" stroke-width="1" opacity="0.7" />
                <path d="M 380 60 L 400 60 L 400 200 L 360 200 Z" fill="currentColor" opacity="0.06" />
                <path d="M 360 200 L 400 200 L 400 240 Z" fill="currentColor" opacity="0.10" />
            </svg>
            <svg class="circuit-bl" viewBox="0 0 400 320" preserveAspectRatio="xMinYMax meet">
                <polyline points="0,40 40,40 40,80 80,80 80,60 120,60" fill="none" stroke="currentColor" stroke-width="1" stroke-linejoin="miter" stroke-linecap="square" opacity="0.35" />
                <polyline points="0,120 60,120 60,160 100,160" fill="none" stroke="currentColor" stroke-width="1" stroke-linejoin="miter" stroke-linecap="square" opacity="0.3" />
                <polyline points="0,200 80,200 80,240 140,240" fill="none" stroke="currentColor" stroke-width="1" stroke-linejoin="miter" stroke-linecap="square" opacity="0.4" />
                <polyline points="0,280 60,280 60,300 120,300 120,320" fill="none" stroke="currentColor" stroke-width="1" stroke-linejoin="miter" stroke-linecap="square" opacity="0.45" />
                <polyline points="20,0 20,40" fill="none" stroke="currentColor" stroke-width="1" stroke-linejoin="miter" stroke-linecap="square" opacity="0.3" />
                <circle cx="40" cy="40" r="2" fill="none" stroke="currentColor" stroke-width="1" opacity="0.6" />
                <circle cx="80" cy="60" r="2.5" fill="currentColor" stroke="currentColor" stroke-width="1" opacity="0.7" />
                <circle cx="120" cy="60" r="3" fill="currentColor" stroke="currentColor" stroke-width="1" opacity="0.9" />
                <circle cx="60" cy="160" r="2" fill="none" stroke="currentColor" stroke-width="1" opacity="0.5" />
                <circle cx="80" cy="240" r="2.5" fill="currentColor" stroke="currentColor" stroke-width="1" opacity="0.7" />
                <circle cx="140" cy="240" r="2" fill="currentColor" stroke="currentColor" stroke-width="1" opacity="0.8" />
                <circle cx="60" cy="280" r="2" fill="none" stroke="currentColor" stroke-width="1" opacity="0.5" />
                <path d="M 0 260 L 40 260 L 40 320 L 0 320 Z" fill="currentColor" opacity="0.06" />
            </svg>
        </div>

        <div class="err-inner">
            <div class="err-eyebrow">
                <span class="err-eyebrow-dot"></span>
                @_copy.Tag
            </div>

            <div class="err-code" aria-label="Error @Code">
                <span class="err-code-digit">@_digits[0]</span>
                <span class="err-code-mark">@_digits[1]</span>
                <span class="err-code-digit">@_digits[2]</span>
            </div>

            <h1 class="err-title">@_copy.Title</h1>
            <p class="err-body">@_copy.Body</p>

            <div class="err-terminal" aria-hidden="true">
                <span class="err-terminal-method">GET</span>
                <span class="err-terminal-path">@_copy.Path</span>
                <span class="err-terminal-arrow">→</span>
                <span class="err-terminal-status">@Code</span>
            </div>

            <div class="err-actions">
                <a href="/" class="btn btn-primary btn-lg">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M19 12H5M12 19l-7-7 7-7" />
                    </svg>
                    <span>Back to homepage</span>
                </a>
                <a href="/#contact" class="btn btn-ghost btn-lg"><span>Get in touch</span></a>
            </div>

            <div class="err-links">
                <a class="err-link" href="/#services"><span class="err-link-num">01</span> Services</a>
                <a class="err-link" href="/#cases"><span class="err-link-num">02</span> Cases</a>
                <a class="err-link" href="/#contact"><span class="err-link-num">03</span> Contact</a>
            </div>
        </div>

        <div class="err-corners" aria-hidden="true">
            <span class="hero-corner hc-tl"></span>
            <span class="hero-corner hc-tr"></span>
            <span class="hero-corner hc-bl"></span>
            <span class="hero-corner hc-br"></span>
        </div>
    </section>
</main>

<footer class="ftr">
    <div class="ftr-inner">
        <div>© 2026 André Goepel · andregoepel.dev</div>
        <div>Crafted with care. Lighthouse ≥ 95.</div>
    </div>
</footer>

@code {
    [Parameter, EditorRequired]
    public required string Code { get; set; }

    private string _theme = "system";
    private string[] _digits = ["4", "0", "4"];
    private bool _isInteractive;

    private ErrorCopy _copy = default!;

    private static readonly Dictionary<string, ErrorCopy> Copies = new()
    {
        ["404"] = new(
            "Error 404 · Not Found",
            "This page took a wrong turn.",
            "The page you're looking for doesn't exist, has moved, or never did. Let's get you back to solid ground.",
            "/page-not-found"
        ),
        ["403"] = new(
            "Error 403 · Forbidden",
            "This area is off-limits.",
            "You don't have permission to view this page. If you believe that's a mistake, reach out and I'll take a look.",
            "/restricted"
        ),
    };

    protected override void OnParametersSet()
    {
        _copy = Copies.GetValueOrDefault(Code, Copies["404"]);
        _digits = Code.Select(c => c.ToString()).ToArray();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        _isInteractive = true;
        var state = await JS.InvokeAsync<InitialState>("site.getInitialState");
        _theme = state.Theme;
        await JS.InvokeVoidAsync("site.applyAttrs", state.ResolvedTheme, state.Lang);
        await JS.InvokeVoidAsync("site.initErrorBg");
        StateHasChanged();
    }

    private async Task SetTheme(string theme)
    {
        _theme = theme;
        var resolved =
            theme == "system"
                ? await JS.InvokeAsync<bool>("eval", "window.matchMedia('(prefers-color-scheme: dark)').matches")
                    ? "dark"
                    : "light"
                : theme;
        await JS.InvokeVoidAsync("site.applyAttrs", resolved, "en");
        await JS.InvokeVoidAsync("site.savePrefs", "en", theme);
    }

    public async ValueTask DisposeAsync()
    {
        if (!_isInteractive)
            return;

        try
        {
            await JS.InvokeVoidAsync("site.stopErrorBg");
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException) { }
    }

    private record ErrorCopy(string Tag, string Title, string Body, string Path);

    private record InitialState(string Lang, string Theme, string ResolvedTheme);
}
